{
  "name": "memo_analytical",
  "strict": true,
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["hypotheses", "swot"],
    "properties": {
      "hypotheses": {
        "type": "object",
        "additionalProperties": false,
        "required": ["statements"],
        "properties": {
          "statements": { "type": "array", "items": { "$ref": "#/$defs/statement" } }
        }
      },
      "swot": {
        "type": "object",
        "additionalProperties": false,
        "required": ["strengths", "weaknesses", "opportunities", "threats"],
        "properties": {
          "strengths":     { "type": "array", "items": { "$ref": "#/$defs/statement" } },
          "weaknesses":    { "type": "array", "items": { "$ref": "#/$defs/statement" } },
          "opportunities": { "type": "array", "items": { "$ref": "#/$defs/statement" } },
          "threats":       { "type": "array", "items": { "$ref": "#/$defs/statement" } }
        }
      }
    },
    "$defs": {
      "statement": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text", "claim_ids", "kind"],
        "properties": {
          "text": { "type": "string" },
          "claim_ids": { "type": "array", "items": { "type": "string" } },
          "kind": { "type": "string", "enum": ["fact", "not_disclosed", "benchmark", "structural"] }
        }
      }
    }
  }
}
