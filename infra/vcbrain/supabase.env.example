# infra/vcbrain/supabase.env.example -- copy to supabase.env (gitignored, chmod 600)
# and fill in real values before `docker compose -p vcbrain --env-file supabase.env up -d`.
# Design: docs/backlog/12-docker-deploy/design.md §6/§7.
# In this deploy, values are REUSED from local infra/supabase/.env so imported-data
# tokens (ANON_KEY/SERVICE_ROLE_KEY) and Studio login keep working unchanged.

POSTGRES_PASSWORD=

JWT_SECRET=
ANON_KEY=
SERVICE_ROLE_KEY=

SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
JWT_KEYS=
JWT_JWKS=

DASHBOARD_USERNAME=
DASHBOARD_PASSWORD=

PG_META_CRYPTO_KEY=

S3_PROTOCOL_ACCESS_KEY_ID=
S3_PROTOCOL_ACCESS_KEY_SECRET=

############
# URLs -- server hostname (design.md §1)
############
SUPABASE_PUBLIC_URL=https://vc-api.prodsignal.me

############
# Database -- vcbrain-db is the only Postgres in this deploy (no pooler,
# design.md §3: migrations/every service connect directly to vcbrain-db:5432).
############
POSTGRES_HOST=vcbrain-db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

############
# Studio
############
STUDIO_DEFAULT_ORGANIZATION="VC Brain"
STUDIO_DEFAULT_PROJECT=vcbrain

############
# Storage
############
GLOBAL_S3_BUCKET=stub
REGION=stub
STORAGE_TENANT_ID=stub

############
# API -- PostgREST
############
PGRST_DB_SCHEMAS=public,graphql_public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public

JWT_EXPIRY=3600

############
# Kong -- unused (no ports published, kept for completeness/parity with kong.yml subs)
############
ANON_KEY_ASYMMETRIC=
SERVICE_ROLE_KEY_ASYMMETRIC=
