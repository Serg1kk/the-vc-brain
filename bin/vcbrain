// ============================================================================
// `search "<nl query>" [--limit N]`
// ============================================================================

async function cmdSearch(argv) {
  const { positional, flags, error } = extractFlags(argv, { limit: true });
  if (flags.help) {
    process.stdout.write(topHelpText());
    process.exitCode = 0;
    return;
  }
  if (error) return usageErrorExit('search', error.message, 'run "vcbrain --help" for usage', flags);
  if (positional.length > 1) {
    return usageErrorExit(
      'search',
      'takes exactly one positional argument -- quote the query string',
      'usage: vcbrain search "<nl query>" [--limit N]',
      flags
    );
  }
  const query = positional[0];
  if (query === undefined) {
    return missingArgExit('search', '<nl query>', 'vcbrain search "<nl query>" [--limit N]', flags);
  }

  const limit = flags.limit != null ? flags.limit : DEFAULT_SEARCH_LIMIT;
  if (limit > PGRST_DB_MAX_ROWS) {
    return failExit(
      'limit_exceeded',
      `--limit ${limit} exceeds PGRST_DB_MAX_ROWS=${PGRST_DB_MAX_ROWS}`,
      { hint: `use --limit <= ${PGRST_DB_MAX_ROWS}`, retryable: false },
      flags,
      1
    );
  }
  if (query.trim() === '') {
    return failExit(
      'empty_query',
      'query is blank or whitespace-only',
      { hint: 'pass a non-empty natural-language query, e.g. vcbrain search "technical founder who ships to production"', retryable: false },
      flags,
      1
    );
  }

  const url = `${n8nUrl()}/f10-nl-search`;
  const result = await postJson(url, { query, limit }, 30000);

  if (!result.ok) {
    return failExit(
      'upstream_timeout',
      `could not reach ${url}: ${result.errMessage}`,
      {
        hint:
          'the f10-nl-search n8n webhook may not be deployed/active yet (feature 10 task C1) -- confirm ' +
          '"docker compose up -d" in infra/n8n/ and that the workflow is active, then retry.',
        retryable: true,
      },
      flags,
      1
    );
  }

  const { status, body } = result;

  if (status === 404) {
    return failExit(
      'upstream_timeout',
      `f10-nl-search webhook returned 404 at ${url} -- not registered or the workflow is inactive`,
      {
        hint: 'the f10-nl-search n8n webhook may not be deployed/active yet (feature 10 task C1) -- confirm it is up and retry.',
        retryable: true,
      },
      flags,
      1
    );
  }

  // The webhook speaks the same envelope this CLI does (design.md SS5.7) --
  // forward a structured error verbatim rather than re-wrapping it.
  if (body && body.error && body.error.kind) {
    emit(body, flags, renderErrorHuman);
    process.exitCode = 1;
    return;
  }

  if (status < 200 || status >= 300) {
    return failExit(
      'upstream_timeout',
      `f10-nl-search returned HTTP ${status}${body ? '' : ' (no JSON body)'}`,
      { hint: body ? JSON.stringify(body).slice(0, 300) : null, retryable: status >= 500 },
      flags,
      1
    );
  }

  emit(body, flags, renderSearchHuman);
  process.exitCode = 0;
}

// ============================================================================
// `founder <id>` and `application <id>` share almost everything: validate ->
// require token -> fetch the one-row view -> not_found if empty -> fetch the
// paginated claims[] sub-list with an exact count -> assemble.
// ============================================================================

async function fetchOneById(cmdName, viewName, idColumn, id, tok, flags) {
  const url = `${restUrl()}/${viewName}?${idColumn}=eq.${encodeURIComponent(id)}`;
  const res = await getJson(url, tok, {});
  if (!res.ok) {
    failExit(
      'upstream_timeout',
      `could not reach ${restUrl()}: ${res.errMessage}`,
      { hint: 'confirm Supabase/Kong is running (docker compose up -d in infra/supabase/)', retryable: true },
      flags,
      1
    );
    return null;
  }
  if (res.status !== 200) {
    failExit(
      'upstream_error',
      `GET ${viewName} returned HTTP ${res.status}`,
      {
        hint: res.body ? JSON.stringify(res.body).slice(0, 300) : 'check VCBRAIN_TOKEN is a valid PostgREST apikey',
        retryable: res.status >= 500,
      },
      flags,
      1
    );
    return null;
  }
  const rows = Array.isArray(res.body) ? res.body : [];
  if (rows.length === 0) {
    failExit(
      'not_found',
      `no ${cmdName} with id "${id}"`,
      { hint: `ids are UUIDs from ${viewName}.${idColumn}`, retryable: false },
      flags,
      1
    );
    return null;
  }
  return rows[0];
}

async function fetchClaims(filterColumn, id, limit, offset, tok, flags) {
  const url =
    `${restUrl()}/api_claims?${filterColumn}=eq.${encodeURIComponent(id)}` +
    `&order=created_at.desc&limit=${limit}&offset=${offset}`;
  const res = await getJson(url, tok, { exactCount: true });
  if (!res.ok) {
    failExit(
      'upstream_timeout',
      `could not reach ${restUrl()}: ${res.errMessage}`,
      { hint: null, retryable: true },
      flags,
      1
    );
    return null;
  }
  if (res.status !== 200 && res.status !== 206) {
    failExit(
      'upstream_error',
      `GET api_claims returned HTTP ${res.status}`,
      { hint: res.body ? JSON.stringify(res.body).slice(0, 300) : null, retryable: res.status >= 500 },
      flags,
      1
    );
    return null;
  }
  const items = Array.isArray(res.body) ? res.body : [];
  const total = res.total != null ? res.total : offset + items.length;
  return { items, total, truncated: offset + items.length < total };
}

function paginationFromFlags(flags) {
  const limit = flags.limit != null ? flags.limit : DEFAULT_CLAIMS_LIMIT;
  const offset = flags.offset != null ? flags.offset : 0;
  return { limit, offset };
}

async function cmdFounder(argv) {
  const { positional, flags, error } = extractFlags(argv, { limit: true, offset: true });
  if (flags.help) {
    process.stdout.write(topHelpText());
    process.exitCode = 0;
    return;
  }
  if (error) return usageErrorExit('founder', error.message, 'run "vcbrain --help" for usage', flags);
  if (positional.length > 1) {
    return usageErrorExit('founder', 'takes exactly one positional argument', 'usage: vcbrain founder <id>', flags);
  }
  const id = positional[0];
  if (id === undefined) return missingArgExit('founder', '<id>', 'vcbrain founder <id>', flags);

  const tok = token();
  if (!tok) return missingTokenExit('founder', flags);

  const { limit, offset } = paginationFromFlags(flags);
  if (limit > PGRST_DB_MAX_ROWS) {
    return failExit(
      'limit_exceeded',
      `--limit ${limit} exceeds PGRST_DB_MAX_ROWS=${PGRST_DB_MAX_ROWS}`,
      { hint: `use --limit <= ${PGRST_DB_MAX_ROWS}`, retryable: false },
      flags,
      1
    );
  }

  const f = await fetchOneById('founder', 'api_founders', 'founder_id', id, tok, flags);
  if (!f) return; // failExit already ran inside fetchOneById

  const claims = await fetchClaims('founder_id', id, limit, offset, tok, flags);
  if (!claims) return;

  const payload = {
    founder_id: f.founder_id,
    full_name: f.full_name,
    headline: f.headline,
    is_synthetic: f.is_synthetic,
    // Never a bare score value: assessed travels beside it always (REQ-003 --
    // absent axis means "not assessed", never zero).
    founder_score: {
      value: f.founder_score,
      trend: f.founder_score_trend,
      confidence: f.founder_score_confidence,
      missing: f.founder_score_missing,
      gaps: f.founder_score_gaps,
      assessed: f.score_assessed,
    },
    obscurity: f.obscurity,
    obscurity_basis: f.obscurity_basis,
    channel: f.channel,
    first_seen_at: f.first_seen_at,
    company: f.company_id != null ? { id: f.company_id, name: f.company_name } : null,
    application_id: f.application_id,
    claims,
  };
  emit(payload, flags, renderFounderHuman);
  process.exitCode = 0;
}

async function cmdApplication(argv) {
  const { positional, flags, error } = extractFlags(argv, { limit: true, offset: true });
  if (flags.help) {
    process.stdout.write(topHelpText());
    process.exitCode = 0;
    return;
  }
  if (error) return usageErrorExit('application', error.message, 'run "vcbrain --help" for usage', flags);
  if (positional.length > 1) {
    return usageErrorExit('application', 'takes exactly one positional argument', 'usage: vcbrain application <id>', flags);
  }
  const id = positional[0];
  if (id === undefined) return missingArgExit('application', '<id>', 'vcbrain application <id>', flags);

  const tok = token();
  if (!tok) return missingTokenExit('application', flags);

  const { limit, offset } = paginationFromFlags(flags);
  if (limit > PGRST_DB_MAX_ROWS) {
    return failExit(
      'limit_exceeded',
      `--limit ${limit} exceeds PGRST_DB_MAX_ROWS=${PGRST_DB_MAX_ROWS}`,
      { hint: `use --limit <= ${PGRST_DB_MAX_ROWS}`, retryable: false },
      flags,
      1
    );
  }

  const a = await fetchOneById('application', 'api_applications', 'application_id', id, tok, flags);
  if (!a) return;

  const claims = await fetchClaims('application_id', id, limit, offset, tok, flags);
  if (!claims) return;

  const payload = {
    application_id: a.application_id,
    company: { id: a.company_id, name: a.company_name, domain: a.company_domain },
    stage: a.stage,
    category: a.category,
    kind: a.kind,
    status: a.status,
    submitted_at: a.submitted_at,
    artifact_links: a.artifact_links,
    // Three independent screening axes, never blended into one number
    // (REQ-002 / invariant #1) -- each already {value,trend,confidence,
    // missing,assessed} straight off the view.
    scores: {
      founder: a.score_founder,
      market: a.score_market,
      idea_vs_market: a.score_idea_vs_market,
    },
    thesis: {
      id: a.thesis_id,
      name: a.thesis_name,
      verdict: a.thesis_verdict,
      fit: a.thesis_fit,
      coverage: a.thesis_coverage,
      missing_fields: a.thesis_missing_fields,
      fired_rules: a.thesis_fired_rules,
    },
    // false on every row today (feature 06 not built) -- truthful, not a
    // placeholder (design.md SS6.4).
    memo: { version: a.memo_version, available: a.memo_available },
    claims,
  };
  emit(payload, flags, renderApplicationHuman);
  process.exitCode = 0;
}

// ============================================================================
// Human (TTY, non --json) renderers -- plain text, no ANSI. `search`'s
// renderer surfaces `confidence_bucket` on the table so the displayed order
// is explicable from what is displayed (design.md SS5.6's own requirement).
// ============================================================================

function scoreLine(label, s) {
  if (!s) return `  ${label}: (no score object)`;
  return `  ${label}: assessed=${s.assessed} value=${s.value ?? 'null'} confidence=${s.confidence ?? 'null'} trend=${s.trend ?? 'null'}` +
    (Array.isArray(s.missing) && s.missing.length ? `  missing=[${s.missing.join(', ')}]` : '');
}

function renderFounderHuman(f) {
  const lines = [];
  lines.push(`Founder ${f.founder_id}`);
  lines.push(`  name: ${f.full_name ?? '(unknown)'}    synthetic: ${f.is_synthetic}`);
  lines.push(`  headline: ${f.headline ?? '(none)'}`);
  lines.push(scoreLine('founder_score', f.founder_score));
  lines.push(`  obscurity: ${f.obscurity ?? 'null'} (${(f.obscurity_basis || []).join(',') || 'no basis'})   first_seen: ${f.first_seen_at ?? 'null'}`);
  lines.push(`  company: ${f.company ? `${f.company.name} (${f.company.id})` : '(none)'}    application_id: ${f.application_id ?? '(none)'}`);
  lines.push(`  claims: ${f.claims.items.length}/${f.claims.total} shown${f.claims.truncated ? '  -- TRUNCATED, use --offset to page' : ''}`);
  for (const c of f.claims.items) {
    lines.push(`    - [${c.verification_status}] ${c.topic}: ${c.text_verbatim ? c.text_verbatim.slice(0, 80) : '(no text)'}`);
  }
  return lines.join('\n');
}

function renderApplicationHuman(a) {
  const lines = [];
  lines.push(`Application ${a.application_id}`);
  lines.push(`  company: ${a.company.name} (${a.company.id})   domain=${a.company.domain ?? 'null'}`);
  lines.push(`  stage=${a.stage ?? 'null'}  category=${a.category ?? 'null'}  kind=${a.kind}  status=${a.status}`);
  lines.push(scoreLine('score_founder', a.scores.founder));
  lines.push(scoreLine('score_market', a.scores.market));
  lines.push(scoreLine('score_idea_vs_market', a.scores.idea_vs_market));
  lines.push(`  thesis: ${a.thesis.name ?? 'null'}  verdict=${a.thesis.verdict ?? 'null'}  fit=${a.thesis.fit ?? 'null'}  coverage=${a.thesis.coverage ?? 'null'}`);
  lines.push(`  memo: available=${a.memo.available}  version=${a.memo.version ?? 'null'}`);
  lines.push(`  claims: ${a.claims.items.length}/${a.claims.total} shown${a.claims.truncated ? '  -- TRUNCATED, use --offset to page' : ''}`);
  for (const c of a.claims.items) {
    lines.push(`    - [${c.verification_status}] ${c.topic}: ${c.text_verbatim ? c.text_verbatim.slice(0, 80) : '(no text)'}`);
  }
  return lines.join('\n');
}

function renderSearchHuman(r) {
  const lines = [];
  lines.push(`query: ${r.query}`);
  if (r.note) lines.push(`note: ${r.note}`);
  const attrs = (r.plan && r.plan.attributes) || [];
  lines.push(`plan.attributes: ${attrs.map((a) => `${a.id}(${a.kind}/${a.polarity}, w=${a.weight})`).join(', ') || '(none)'}`);
  const unresolvable = (r.plan && r.plan.unresolvable) || [];
  if (unresolvable.length) lines.push(`unresolvable: ${unresolvable.map((u) => `${u.label} [${u.reason}]`).join(', ')}`);
  lines.push(`total=${r.total}  truncated=${r.truncated}  low_confidence_only=${r.low_confidence_only}`);
  lines.push('');
  lines.push('bucket  rank    conf  founder_id                            name');
  for (const it of r.items || []) {
    lines.push(
      `${String(it.confidence_bucket ?? 'null').padEnd(6)}  ${String(it.rank_score ?? 'null').padEnd(6)}  ${String(it.confidence).padEnd(4)}  ${it.founder_id}  ${it.full_name ?? ''}`
    );
  }
  if (r.low_confidence && r.low_confidence.length) {
    lines.push('');
    lines.push(`-- low_confidence[] (${r.low_confidence.length}, below the confidence floor, never interleaved above) --`);
    for (const it of r.low_confidence) lines.push(`  ${it.founder_id}  conf=${it.confidence}`);
  }
  return lines.join('\n');
}

// ============================================================================
// Help text (design.md SS6.2: "vcbrain --help must mention schema; the
// schema command is how an agent discovers the tool when nothing is
// configured yet.").
// ============================================================================

function topHelpText() {
  return `vcbrain -- read-only CLI for the VC Brain platform (PostgREST + n8n).
Primary consumer is an AI agent: --json is the default when stdout is not a TTY, every list
response is wrapped { items, total, truncated }, every failure is { error: { kind, message,
hint, retryable } }.

USAGE
  vcbrain schema                                       static, offline, no token required
  vcbrain search "<nl query>" [--limit N]               POST {VCBRAIN_N8N_URL}/f10-nl-search
  vcbrain founder <id> [--limit N] [--offset N]         GET {VCBRAIN_REST_URL}/api_founders + api_claims
  vcbrain application <id> [--limit N] [--offset N]     GET {VCBRAIN_REST_URL}/api_applications + api_claims

Run "vcbrain schema" first -- it documents the full contract, every command, every error kind,
and the exact view columns, and needs no token/config/network to answer.

ENV
  VCBRAIN_TOKEN       PostgREST apikey/Authorization token. Required for founder/application.
                      WARNING: full read+write access to every table -- demo credential only.
  VCBRAIN_REST_URL    default ${DEFAULT_REST_URL}
  VCBRAIN_N8N_URL     default ${DEFAULT_N8N_URL}

EXIT CODES
  0  success
  1  structured error (kind-based -- see "vcbrain schema")
  2  usage error (bad/missing argument or flag)

This CLI is deliberately four commands. Deliberately absent: submit, founders/applications/claims
(list verbs), score, gate, memo, watch -- run any of those names for a structured explanation of
why, rather than an "unknown command".
`;
}

// ============================================================================
// Dispatch. Verbs a hallucinating agent is likely to try are matched
// explicitly and answered with `not_yet_available` + a real reason
// (design.md SS6.3/SS6.4) rather than falling through to a generic
// "unknown command" -- see the task report for why this is a judgment call
// beyond what design.md states verbatim.
// ============================================================================

const KNOWN_COMMANDS = ['schema', 'search', 'founder', 'application'];

const NOT_YET_AVAILABLE = {
  memo:
    'feature 06 (memo generation) has not landed -- api_applications.memo_available is false on every ' +
    'row today. Read that field via "vcbrain application <id>" instead of a memo command that would have ' +
    'to fabricate one.',
  watch: 'the watchlist table exists but is empty and no feature populates it yet.',
  submit:
    'feature 10 is read-only by design -- companies.stage has no default (every insert fails 23502) and ' +
    "deck upload belongs to feature 08's POST /webhook/f08-intake-submit.",
  score:
    'the f03-score-founder webhook exists and is documented in the vcbrain-cli skill for agents that want ' +
    'to trigger scoring directly -- this CLI does not wrap it.',
  gate:
    'the f07-thesis-gate webhook exists and is documented in the vcbrain-cli skill for agents that want to ' +
    'trigger the thesis gate directly -- this CLI does not wrap it.',
  founders: `there is no enumeration verb -- "search" is the only discovery route. Read GET ${DEFAULT_REST_URL}/api_founders directly.`,
  applications: `there is no enumeration verb -- see "founders". Read GET ${DEFAULT_REST_URL}/api_applications directly.`,
  claims: `there is no enumeration verb -- see "founders". Read GET ${DEFAULT_REST_URL}/api_claims directly.`,
  list: 'there is no enumeration verb in this CLI -- see "founders"/"applications"/"claims".',
};

async function main() {
  const argv = process.argv.slice(2);
  const cmd = argv[0];
  const rest = argv.slice(1);

  if (cmd === '--help' || cmd === '-h' || cmd === 'help') {
    process.stdout.write(topHelpText());
    process.exitCode = 0;
    return;
  }

  if (cmd === undefined) {
    const flags = extractFlags(rest, {}).flags;
    failExit(
      'usage_error',
      'vcbrain: no command given',
      { hint: `commands: ${KNOWN_COMMANDS.join(', ')}. Run "vcbrain --help" for usage.`, retryable: false },
      flags,
      2
    );
    return;
  }

  if (Object.prototype.hasOwnProperty.call(NOT_YET_AVAILABLE, cmd)) {
    const flags = extractFlags(rest, {}).flags;
    failExit('not_yet_available', `"vcbrain ${cmd}" is not implemented`, { hint: NOT_YET_AVAILABLE[cmd], retryable: false }, flags, 1);
    return;
  }

  if (!KNOWN_COMMANDS.includes(cmd)) {
    const flags = extractFlags(rest, {}).flags;
    failExit(
      'usage_error',
      `unknown command "${cmd}"`,
      { hint: `commands: ${KNOWN_COMMANDS.join(', ')}. Run "vcbrain --help" for usage.`, retryable: false },
      flags,
      2
    );
    return;
  }

  if (cmd === 'schema') {
    const { flags, error } = extractFlags(rest, {});
    if (flags.help) {
      process.stdout.write(topHelpText());
      process.exitCode = 0;
      return;
    }
    if (error) return usageErrorExit('schema', error.message, 'run "vcbrain --help" for usage', flags);
    emit(buildSchemaPayload(), flags);
    process.exitCode = 0;
    return;
  }
  if (cmd === 'search') return cmdSearch(rest);
  if (cmd === 'founder') return cmdFounder(rest);
  if (cmd === 'application') return cmdApplication(rest);
}

main().catch((err) => {
  const flags = { json: !process.stdout.isTTY };
  failExit(
    'upstream_timeout',
    `unexpected error: ${err.message}`,
    { hint: err.stack ? err.stack.split('\n').slice(0, 3).join(' | ') : null, retryable: true },
    flags,
    1
  );
});
