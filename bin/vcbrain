#!/usr/bin/env node
// bin/vcbrain
//
// The `vcbrain` CLI -- feature 10's thin, read-only surface over PostgREST
// (api_founders / api_applications / api_claims, design.md SS4) and n8n's
// f10-nl-search webhook (design.md SS5). Node, ZERO dependencies -- the repo
// has no package.json (design.md SS6.1) and Node 22's built-in `fetch` /
// `AbortController` cover everything this file needs.
//
// Primary consumer is an AI agent, not a human (design.md SS6.2, clispec.dev-
// shaped): every list is `{ items, total, truncated }`, never a bare array;
// every failure is `{ error: { kind, message, hint, retryable } }`; JSON is
// the default whenever stdout is not a TTY; nothing ever prompts; a command
// missing a required argument exits 2 and names it. Exit codes: 0 success ·
// 1 structured error (kind-based) · 2 usage error (bad/missing CLI input).
//
// Four commands, nothing else (design.md SS6.3): `schema` (static, offline,
// no token) · `search "<nl query>" [--limit N]` (POST f10-nl-search) ·
// `founder <id>` (GET api_founders + api_claims) · `application <id>` (GET
// api_applications + api_claims). Every other verb a hallucinating agent
// might try (`submit`, `founders`/`applications`/`claims` list verbs,
// `score`, `gate`, `memo`, `watch`) is caught explicitly below and answered
// with a structured `not_yet_available` error naming the real reason
// (design.md SS6.3/SS6.4) rather than a generic "unknown command" -- see
// NOT_YET_AVAILABLE.
//
// docs/backlog/10-api-cli-skill/design.md rev.5 SS6, plan.md task D1.

'use strict';

// ============================================================================
// Config (design.md "## Config") -- env only, no .env auto-load, no silent
// defaults for the token. `schema` must work with none of this set.
// ============================================================================

const DEFAULT_REST_URL = 'http://localhost:8000/rest/v1';
const DEFAULT_N8N_URL = 'http://localhost:5678/webhook';
// infra/supabase/.env's own value, restated here because design.md SS6.2
// cites it directly ("respecting PGRST_DB_MAX_ROWS=1000") -- this file has
// no way to read the live Postgres config at "schema" time (no token, no
// network), so the documented default is the only honest source.
const PGRST_DB_MAX_ROWS = 1000;
const DEFAULT_SEARCH_LIMIT = 10; // design.md SS5.4 rule 5
const DEFAULT_CLAIMS_LIMIT = 50; // not specified by design.md -- this CLI's own default page size for the embedded claims[] on founder/application (see report)

const CLAIM_SELECT =
  'claim_id,card_id,founder_id,company_id,application_id,topic,axis,text_verbatim,value,source_kind,base_confidence,verification_status,created_at,evidence';

function restUrl() {
  return String(process.env.VCBRAIN_REST_URL || DEFAULT_REST_URL).replace(/\/+$/, '');
}
function n8nUrl() {
  return String(process.env.VCBRAIN_N8N_URL || DEFAULT_N8N_URL).replace(/\/+$/, '');
}
function token() {
  return process.env.VCBRAIN_TOKEN || '';
}

// ============================================================================
// Error envelope (design.md SS5.7 / SS6.2) -- one shape, reused by every
// command AND by the search webhook's own pass-through (the webhook "reuses
// the CLI envelope", SS5.7 -- so when it already answers in this shape this
// CLI forwards it verbatim rather than re-wrapping).
// ============================================================================

function errorEnvelope(kind, message, opts) {
  const o = opts || {};
  return { error: { kind, message, hint: o.hint != null ? o.hint : null, retryable: o.retryable === true } };
}

// ============================================================================
// Output plumbing. `--json` is the default whenever stdout is not a TTY
// (design.md SS6.2); when it IS a TTY and `--json` was not passed, a human
// renderer is used instead -- plain text, no ANSI escapes anywhere in this
// file (simplest way to guarantee "no ANSI when piped": never emit any).
// `process.exitCode` is used rather than `process.exit()` so buffered stdout
// is never cut off mid-write on a piped consumer (verified against `| python3
// -m json.tool` below).
// ============================================================================

function isJsonMode(flags) {
  return (flags && flags.json === true) || !process.stdout.isTTY;
}

function emit(payload, flags, humanFn) {
  if (isJsonMode(flags) || typeof humanFn !== 'function') {
    process.stdout.write(JSON.stringify(payload, null, 2) + '\n');
  } else {
    process.stdout.write(humanFn(payload) + '\n');
  }
}

function renderErrorHuman(env) {
  const e = env.error;
  const lines = [`Error [${e.kind}]: ${e.message}`];
  if (e.hint) lines.push(`hint: ${e.hint}`);
  lines.push(`retryable: ${e.retryable}`);
  return lines.join('\n');
}

function failExit(kind, message, opts, flags, code) {
  const env = errorEnvelope(kind, message, opts);
  emit(env, flags, renderErrorHuman);
  process.exitCode = code == null ? 1 : code;
}

// `usage_error` is THIS CLI's own kind, not one of design.md SS5.7's six or
// the three SS6.2 adds (missing_token/not_found/not_yet_available) -- see
// the task report's "ambiguity" section. Always exit 2.
function usageErrorExit(cmdName, message, hint, flags) {
  failExit('usage_error', `vcbrain ${cmdName}: ${message}`, { hint, retryable: false }, flags, 2);
}

function missingArgExit(cmdName, argName, usageLine, flags) {
  usageErrorExit(cmdName, `missing required argument ${argName}`, `usage: ${usageLine}`, flags);
}

function missingTokenExit(cmdName, flags) {
  failExit(
    'missing_token',
    `VCBRAIN_TOKEN is not set -- required for "vcbrain ${cmdName}" (sent as PostgREST's apikey + Authorization: Bearer header)`,
    {
      hint:
        'export VCBRAIN_TOKEN=<a token from infra/supabase/.env, e.g. ANON_KEY>. WARNING: this token ' +
        'has full read AND WRITE access to every table in the database, including theses and claims -- ' +
        'it is a demo credential, not production auth (design.md SS3.2).',
      retryable: false,
    },
    flags,
    1
  );
}

// ============================================================================
// Argument parsing -- flat, no external parser (zero deps). `--json` and
// `--help`/`-h` are recognised for every command; `--limit`/`--offset` only
// where `spec` opts them in. Unrecognised flags and malformed values are
// collected as usage errors, never silently ignored and never prompted for.
// ============================================================================

function extractFlags(args, spec) {
  const s = spec || {};
  const positional = [];
  const flags = {};
  let error = null; // first usage problem found, named

  for (let i = 0; i < args.length; i++) {
    const a = args[i];
    if (a === '--json') {
      flags.json = true;
      continue;
    }
    if (a === '--help' || a === '-h') {
      flags.help = true;
      continue;
    }
    if (a === '--limit' || a === '--offset') {
      const name = a.slice(2);
      if (!s[name]) {
        error = error || { flag: a, message: `"${a}" is not a recognised flag for this command` };
        continue;
      }
      const raw = args[i + 1];
      i += 1;
      if (raw === undefined) {
        error = error || { flag: a, message: `${a} requires a value` };
        continue;
      }
      const n = Number(raw);
      if (!Number.isInteger(n) || n < 0) {
        error = error || { flag: a, message: `${a} must be a non-negative integer (got "${raw}")` };
        continue;
      }
      flags[name] = n;
      continue;
    }
    if (a.startsWith('--')) {
      error = error || { flag: a, message: `unrecognised flag "${a}"` };
      continue;
    }
    positional.push(a);
  }

  return { positional, flags, error };
}

// ============================================================================
// HTTP helpers -- thin wrappers over the built-in `fetch`. Neither throws on
// a non-2xx status; callers branch on `.ok`/`.status` explicitly so every
// failure path maps to a named error kind instead of an uncaught exception.
// ============================================================================

async function getJson(url, tok, opts) {
  const o = opts || {};
  const headers = { apikey: tok, Authorization: `Bearer ${tok}` };
  if (o.exactCount) headers.Prefer = 'count=exact';
  try {
    const res = await fetch(url, { headers });
    let body = null;
    try {
      body = await res.json();
    } catch (_e) {
      body = null;
    }
    let total = null;
    const cr = res.headers.get('content-range'); // "0-9/42" or "*/0" or "0-9/*"
    if (cr) {
      const m = /\/(\d+|\*)$/.exec(cr);
      if (m && m[1] !== '*') total = Number(m[1]);
    }
    return { ok: true, status: res.status, body, total };
  } catch (e) {
    return { ok: false, errMessage: e.message };
  }
}

async function postJson(url, payload, timeoutMs) {
  const controller = new AbortController();
  const timer = setTimeout(() => controller.abort(), timeoutMs);
  try {
    const res = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
      signal: controller.signal,
    });
    clearTimeout(timer);
    let body = null;
    try {
      body = await res.json();
    } catch (_e) {
      body = null;
    }
    return { ok: true, status: res.status, body };
  } catch (e) {
    clearTimeout(timer);
    const errMessage = e.name === 'AbortError' ? `timed out after ${timeoutMs}ms` : e.message;
    return { ok: false, errMessage };
  }
}

// ============================================================================
// `schema` -- static, offline, no token, no network (design.md SS6.2's own
// requirement: "an agent reaches for the schema precisely when nothing is
// set up"). Every field below is either a literal from design.md or a
// column list transcribed from the live `CREATE VIEW` statements in
// db/schema.sql (SS4.1-SS4.3) -- nothing here is inferred or guessed.
// ============================================================================

