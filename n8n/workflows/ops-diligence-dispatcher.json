      "name": "GET dispatch guard events",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1300,
        0
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const ctx = $('Extract market scores').first().json;\nconst rows = $input.all().flatMap(i => { try { const p = JSON.parse((i.json && i.json.data) || 'null'); return Array.isArray(p) ? p : (p ? [p] : []); } catch (e) { return []; } }) // postgrestNode() returns raw text (see f04-market-intel.json convention) -- parsed here, never relying on n8n's own array-unwrapping (verified live there: it is inconsistent for empty-array responses -- sometimes 0 items, sometimes 1 item with json={} -- either of which silently corrupts this check);\nconst dispatchedIds = rows.map(r => r.entity_id).filter(Boolean);\nreturn [{ json: { ...ctx, dispatched_application_ids: dispatchedIds } }];"
      },
      "id": "16342b03-df73-4b7d-b5ba-104754698aca",
      "name": "Extract dispatch guard events",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1560,
        0
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const ctx = $input.first().json;\nconst scoredSet = new Set(ctx.scored_application_ids || []);\nconst dispatchedSet = new Set(ctx.dispatched_application_ids || []);\nconst candidates = (ctx.pending_applications || [])\n  .filter(a => a && a.id && !scoredSet.has(a.id) && !dispatchedSet.has(a.id))\n  .sort((a, b) => new Date(a.created_at) - new Date(b.created_at));\n// Exactly ONE application per tick (cost bound, design note in README-ops-dispatcher.md):\n// every-minute ticks drain a queue anyway, and this keeps the diligence-chain cost per\n// tick predictable regardless of how many applications are momentarily pending.\nconst chosen = candidates.length ? candidates[0] : null;\nreturn [{ json: {\n  candidate_found: !!chosen,\n  application_id: chosen ? chosen.id : null,\n  application_created_at: chosen ? chosen.created_at : null,\n  candidate_pool_size: candidates.length,\n} }];"
      },
      "id": "399c6778-1f8d-4dee-a959-e8d20ca73abd",
      "name": "Pick next candidate",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1820,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "f08e71d3-ac65-4351-a700-9f5e1be0eb1b",
              "leftValue": "={{ $json.candidate_found }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "d3bd1591-1206-49fa-8f58-5ae0152be570",
      "name": "Candidate found?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
