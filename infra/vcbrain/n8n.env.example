# infra/vcbrain/n8n.env.example -- copy to n8n.env (gitignored, chmod 600) and fill
# in real values before `docker compose -p vcbrain-n8n --env-file n8n.env -f
# n8n-compose.yml up -d`. Design: docs/backlog/12-docker-deploy/design.md §6.
# SUPABASE_URL points at the REMOTE vcbrain-kong (not host.docker.internal like
# local infra/n8n/.env) -- includes /rest/v1 to match the local working shape so
# f04/f09/f10/f11 workflows' $env.SUPABASE_URL-based HTTP Request nodes need no edits.

SUPABASE_URL=http://vcbrain-kong:8000/rest/v1
SUPABASE_SERVICE_ROLE_KEY=
TAVILY_API_KEY=
OPENAI_API_KEY=
