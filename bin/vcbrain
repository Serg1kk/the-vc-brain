        flags: ['--limit N (default 50, applies to claims[])', '--offset N', '--json'],
        backing: `GET ${DEFAULT_REST_URL}/api_applications + api_claims (VCBRAIN_REST_URL)`,
        requires_token: true,
        description:
          'One application -- three independent screening axes (never blended, REQ-002), thesis fit, ' +
