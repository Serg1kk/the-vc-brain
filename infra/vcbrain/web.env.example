# infra/vcbrain/web.env.example -- copy to web.env (gitignored, chmod 600) and fill
# in real values before `docker compose -p vcbrain-web --env-file web.env -f
# web-compose.yml build`. Build-time-only VITE_* args (design.md §5/§6) -- not
# consumed at container runtime, nitro/vite bakes these in at build.

VITE_SUPABASE_REST_URL=https://vc-api.prodsignal.me/rest/v1
VITE_SUPABASE_ANON_KEY=
VITE_N8N_BASE_URL=https://vc-n8n.prodsignal.me
# Feature 09's demo-grade client-side gate on /app/* -- NOT real auth (web/src/lib/dashboard-auth.ts).
VITE_DASHBOARD_USER=
VITE_DASHBOARD_PASSWORD=
