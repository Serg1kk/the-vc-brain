      list_envelope: '{ items: [...], total: N, truncated: bool } on every list result -- never a bare array.',
      error_envelope: '{ error: { kind, message, hint, retryable } } on every failure.',
      json_default:
        'JSON is emitted whenever stdout is not a TTY, or --json is passed explicitly. No ANSI escapes are ever emitted by this CLI.',
      exit_codes: {
        '0': 'success',
        '1': 'structured error (kind-based, see error_kinds below)',
        '2': 'usage error -- bad or missing CLI argument/flag, never a hang or a prompt',
      },
