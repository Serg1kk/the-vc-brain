      "name": "GET market scores",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        780,
        0
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const ctx = $('Extract pending applications').first().json;\nconst rows = $input.all().flatMap(i => { try { const p = JSON.parse((i.json && i.json.data) || 'null'); return Array.isArray(p) ? p : (p ? [p] : []); } catch (e) { return []; } }) // postgrestNode() returns raw text (see f04-market-intel.json convention) -- parsed here, never relying on n8n's own array-unwrapping (verified live there: it is inconsistent for empty-array responses -- sometimes 0 items, sometimes 1 item with json={} -- either of which silently corrupts this check);\nconst scoredIds = rows.map(r => r.application_id).filter(Boolean);\nreturn [{ json: { ...ctx, scored_application_ids: scoredIds } }];"
      },
      "id": "6c5711a7-eb98-42c0-9ef5-65799eed336a",
      "name": "Extract market scores",
      "type": "n8n-nodes-base.code",
