    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const rows = $input.all().flatMap(i => { try { const p = JSON.parse((i.json && i.json.data) || 'null'); return Array.isArray(p) ? p : (p ? [p] : []); } catch (e) { return []; } }) // postgrestNode() returns raw text (see f04-market-intel.json convention) -- parsed here, never relying on n8n's own array-unwrapping (verified live there: it is inconsistent for empty-array responses -- sometimes 0 items, sometimes 1 item with json={} -- either of which silently corrupts this check);\nreturn [{ json: { pending_applications: rows } }];"
      },
      "id": "f3175ee0-27a5-4452-ac7b-6d702f66c892",
