      VCBRAIN_REST_URL: { required_for: [], purpose: 'PostgREST base URL', default: DEFAULT_REST_URL },
      VCBRAIN_N8N_URL: { required_for: [], purpose: 'n8n webhook base URL', default: DEFAULT_N8N_URL },
    },
    commands: {
      schema: {
        args: [],
        flags: ['--json'],
        backing: 'static, offline',
        description: 'This document. Works with no token, no config, no network.',
      },
      search: {
        args: ['<nl query>'],
        flags: ['--limit N (default 10)', '--json'],
        backing: `POST ${DEFAULT_N8N_URL}/f10-nl-search (VCBRAIN_N8N_URL)`,
        requires_token: false,
        description:
          'Multi-attribute natural-language search resolved in one pass (design.md SS5). Returns founders ' +
          'ranked by confidence_bucket (high>mid>low) then rank_score, each with per-attribute evidence. ' +
          'unresolved attributes and scope-broadening are echoed in `plan` so the caller sees how its ' +
          'words were interpreted.',
